generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                    String              @id @default(uuid())
  email                 String?             @unique
  passwordHash          String?
  name                  String
  role                  Role                @default(customer)
  phone                 String?             @unique
  avatar                String?
  rewardPoints          Int                 @default(0)
  walletBalance         Float               @default(0.0)
  gender                String?
  dob                   String?
  bloodGroup            String?
  emergencyContact      String?
  emailVerified         Boolean             @default(false)
  mobileVerified        Boolean             @default(false)
  biometricsEnabled     Boolean             @default(false)
  biometricCredentialId String?
  lastLoginAt           DateTime?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  fcmToken              String?
  activityLogs          ActivityLog[]
  addresses             Address[]
  cartItems             CartItem[]
  notifications         Notification[]
  orders                Order[]
  refreshTokens         RefreshToken[]
  reviews               Review[]
  walletTransactions    WalletTransaction[]
  wishlistItems         WishlistItem[]
}

model Address {
  id        String   @id @default(uuid())
  userId    String
  name      String
  phone     String
  street    String
  village   String?
  city      String?
  mandal    String?
  district  String
  state     String
  pincode   String
  landmark  String?
  type      String   @default("Home")
  latitude  Float?
  longitude Float?
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Category {
  id        String    @id @default(uuid())
  name      String    @unique
  slug      String    @unique
  createdAt DateTime  @default(now())
  products  Product[]
}

model Product {
  id                       String         @id @default(uuid())
  sku                      String         @unique
  name                     String
  categoryId               String
  brand                    String
  description              String
  ingredients              String
  storage                  String
  nutrition                Json
  weight                   String
  volume                   String
  mrp                      Float
  price                    Float
  discount                 Float
  gst                      Float
  stock                    Int            @default(0)
  status                   String         @default("Available")
  expiryDays               Int
  deliveryTime             String
  rating                   Float          @default(5.0)
  images                   String[]
  tags                     String[]
  frequentlyBoughtTogether String[]
  relatedProducts          String[]
  variants                 Json?
  faq                      Json?
  createdAt                DateTime       @default(now())
  cartItems                CartItem[]
  inventoryLogs            InventoryLog[]
  orderItems               OrderItem[]
  category                 Category       @relation(fields: [categoryId], references: [id])
  reviews                  Review[]
  wishlistItems            WishlistItem[]
}

model Order {
  id                   String           @id
  userId               String
  subtotal             Float
  gstTotal             Float
  deliveryCharges      Float
  discount             Float
  grandTotal           Float
  status               String           @default("Pending")
  paymentMethod        String
  paymentStatus        String           @default("Pending")
  deliverySlot         String?
  giftMessage          String?
  deliveryInstructions String?
  deliveryOtp          String?
  expectedDelivery     DateTime?
  deliveredAt          DateTime?
  cancellationReason   String?
  refundStatus         String?
  refundAmount         Float?
  subscriptionType     String           @default("One Time Order")
  invoiceNumber        String?
  createdAt            DateTime         @default(now())
  deliveryPartnerId    String?
  couponCode           String?
  deliveryAddress      Json?
  timeline             Json?
  deliveryPartner      DeliveryPartner? @relation(fields: [deliveryPartnerId], references: [id])
  user                 User             @relation(fields: [userId], references: [id])
  items                OrderItem[]
  payments             Payment[]
  refunds              Refund[]
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  productId String
  sku       String
  name      String
  price     Float
  quantity  Int
  gst       Float
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])
}

model Payment {
  id        String   @id @default(uuid())
  orderId   String
  paymentId String   @unique
  method    String
  status    String
  amount    Float
  createdAt DateTime @default(now())
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model Refund {
  id        String   @id @default(uuid())
  orderId   String
  amount    Float
  status    String   @default("Pending")
  note      String?
  createdAt DateTime @default(now())
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model InventoryLog {
  id        String   @id @default(uuid())
  productId String
  quantity  Int
  notes     String?
  addedBy   String   @default("Admin")
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  type      String   @default("Order Updates")
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Review {
  id                 String   @id @default(uuid())
  productId          String
  userId             String
  userName           String
  userAvatar         String?
  rating             Int
  title              String
  description        String
  images             String[]
  videos             String[]
  isVerifiedPurchase Boolean  @default(false)
  status             String   @default("pending")
  helpfulCount       Int      @default(0)
  likeCount          Int      @default(0)
  helpfulVotes       Json?
  likes              Json?
  reports            Json?
  adminReply         String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  product            Product  @relation(fields: [productId], references: [id])
  user               User     @relation(fields: [userId], references: [id])
}

model Coupon {
  id          String    @id @default(uuid())
  code        String    @unique
  description String
  type        String    @default("flat")
  value       Float
  minPurchase Float
  maxDiscount Float?
  expiryDate  DateTime?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
}

model DeliveryPartner {
  id                  String   @id @default(uuid())
  name                String
  phone               String
  email               String?
  vehicle             String
  vehicleNumber       String?
  isActive            Boolean  @default(true)
  currentOrderId      String?
  completedDeliveries Int      @default(0)
  rating              Float    @default(5.0)
  createdAt           DateTime @default(now())
  orders              Order[]
}

model ActivityLog {
  id        String   @id @default(uuid())
  userId    String
  type      String
  meta      Json?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CartItem {
  id        String   @id @default(uuid())
  userId    String
  productId String
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
}

model WishlistItem {
  id        String   @id @default(uuid())
  userId    String
  productId String
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
}

model WalletTransaction {
  id           String   @id @default(uuid())
  userId       String
  type         String
  amount       Float
  balanceAfter Float
  description  String
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SupportTicket {
  id         String   @id @default(uuid())
  userId     String?
  name       String
  email      String
  phone      String?
  subject    String
  message    String
  status     String   @default("Pending")
  priority   String   @default("Normal")
  adminReply String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model WhatsAppLog {
  id        String   @id @default(uuid())
  orderId   String
  recipient String
  event     String
  message   String
  status    String   @default("Sent")
  attempts  Int      @default(1)
  error     String?
  createdAt DateTime @default(now())
}

model AppSettings {
  id                           String  @id @default(uuid())
  whatsappNotificationsEnabled Boolean @default(true)
}

enum Role {
  admin
  customer
}
